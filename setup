#!/usr/bin/env bash
set -e

SKILLS_DIR="$HOME/.claude/skills"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1}" == "--verify" ]]; then
  echo "Verifying codebase-oracle installation..."
  echo ""
  PASS=true

  for skill_dir in "$REPO_DIR/skills"/*/; do
    skill_name="$(basename "$skill_dir")"
    link="$SKILLS_DIR/$skill_name"

    if [ ! -e "$link" ]; then
      echo "  FAIL  $skill_name — symlink missing in ~/.claude/skills/"
      PASS=false
    elif [ ! -d "$link" ]; then
      echo "  FAIL  $skill_name — symlink target is not a directory"
      PASS=false
    elif [ ! -f "$link/SKILL.md" ]; then
      echo "  FAIL  $skill_name — SKILL.md not found"
      PASS=false
    else
      echo "  OK    $skill_name"
    fi
  done

  echo ""
  HOOK_PATH="$REPO_DIR/.git/hooks/post-merge"
  if [ -f "$HOOK_PATH" ] && grep -q "codebase-oracle setup" "$HOOK_PATH"; then
    echo "  OK    post-merge hook installed"
  else
    echo "  WARN  post-merge hook not installed — run ./setup to fix"
  fi

  echo ""
  if [ "$PASS" = true ]; then
    echo "All checks passed. Oracle skills are ready."
    exit 0
  else
    echo "Some checks failed. Re-run ./setup to fix."
    exit 1
  fi
fi

mkdir -p "$SKILLS_DIR"

for skill_dir in "$REPO_DIR/skills"/*/; do
  skill_name="$(basename "$skill_dir")"
  ln -sfn "$skill_dir" "$SKILLS_DIR/$skill_name"
  echo "  ✓ $skill_name"
done

echo ""

# Install a post-merge hook so git pull auto-runs setup
HOOK_PATH="$REPO_DIR/.git/hooks/post-merge"
if [ -f "$HOOK_PATH" ] && grep -q "codebase-oracle setup" "$HOOK_PATH"; then
  echo "Git hook already installed — skipping."
else
  cat >> "$HOOK_PATH" << 'EOF'

# -- codebase-oracle setup --
"$(git rev-parse --show-toplevel)/setup"
EOF
  chmod +x "$HOOK_PATH"
  echo "Git hook installed — skills will auto-update on git pull."
fi

echo ""
echo "Done. Oracle skills are available in all Claude Code sessions."
